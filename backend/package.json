{
    "name": "cnpm-tutor-backend",
    "version": "1.0.0",
    "description": "Backend API for CNPM Tutor System with 3 roles: student, instructor, admin",
    "main": "server.js",
    "scripts": {
        "start": "node server.js",
        "dev": "nodemon server.js",
        "seed": "node seeds/seed.users.js",
        "seed:classes": "node seeds/seed.classes.js",
        "seed:instructor": "node seeds/seed.instructor.js",
        "seed:all": "node seeds/seed.users.js && node seeds/seed.classes.js",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "test:integration": "jest --testPathPattern=integration"
    },
    "keywords": [
        "tutor",
        "education",
        "express",
        "mongodb"
    ],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "bcryptjs": "^2.4.3",
        "cookie-parser": "^1.4.6",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "express-validator": "^7.0.1",
        "helmet": "^7.1.0",
        "jsonwebtoken": "^9.0.2",
        "mongoose": "^8.0.3",
        "morgan": "^1.10.0",
        "node-schedule": "^2.1.1",
        "nodemailer": "^6.9.7"
    },
    "devDependencies": {
        "nodemon": "^3.0.2",
        "jest": "^29.7.0",
        "supertest": "^6.3.3",
        "artillery": "^2.0.0"
    }
}